# Harness Trainer Environment Variables

# OpenRouter API key (required for Judge model)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Override default judge model
JUDGE_MODEL=anthropic/claude-3-5-sonnet-20241022

# Optional: Default runtime for agent execution
DEFAULT_RUNTIME=openclaw

# Optional: Default timeout in milliseconds
DEFAULT_TIMEOUT_MS=300000
